# ============================================================
# Energy Project Intelligence Engine - Environment Variables
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/energy_intelligence
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/energy_intelligence

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Geolocation ---
OPENCAGE_API_KEY=your-opencage-api-key-here

# --- Redis (for Celery task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- SEC EDGAR ---
EDGAR_BASE_URL=https://efts.sec.gov/LATEST/search-index
EDGAR_SEARCH_URL=https://efts.sec.gov/LATEST/search-index?q=%22renewable+energy%22&dateRange=custom&startdt=2020-01-01&enddt=2024-12-31&forms=10-K,8-K,S-1
EDGAR_FILING_BASE=https://www.sec.gov
SEC_USER_AGENT=EnergyIntelligenceEngine research@yourdomain.com

# --- App Settings ---
APP_ENV=development
APP_SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MAX_CONCURRENT_SCRAPES=5
BATCH_SIZE=10
CACHE_TTL=3600

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Energy Project Intelligence Engine
